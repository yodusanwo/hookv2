# Copy to `.env.local` for local dev. In Vercel: Project → Settings → Environment Variables
# (add to Production and Preview). Redeploy after changing NEXT_PUBLIC_* — they are inlined at build time.

# Klaviyo onsite script + promo banner coupon popup (`components/PromoBanner.tsx`)
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=
NEXT_PUBLIC_KLAVIYO_COUPON_FORM_ID=

# Google Tag Manager Web container (`app/components/GoogleTagManager.tsx`) — Hook Point: GTM-M8T55SL5
NEXT_PUBLIC_GTM_ID=
