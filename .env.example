# Klaviyo onsite (popup forms, banner) — https://www.klaviyo.com
# Public company ID from Klaviyo Settings → API keys / install snippet (6 characters).
NEXT_PUBLIC_KLAVIYO_COMPANY_ID=
# Form ID from the form editor URL (e.g. …/forms/VqBfhi → VqBfhi)
NEXT_PUBLIC_KLAVIYO_COUPON_FORM_ID=

# Contact form (Resend) — https://resend.com
RESEND_API_KEY=
# Where contact submissions are delivered
CONTACT_TO_EMAIL=hello@hookpointfish.com
# Sender shown in inbox; use a domain verified in Resend for production.
# Trial: onboarding@resend.dev may only deliver to your Resend signup email.
CONTACT_FROM_EMAIL=Hook Point <onboarding@resend.dev>
